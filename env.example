# Rename this file to ".env" and fill in your own API keys.
# Never commit your real .env file — it's already excluded via .gitignore.

# Get your key from https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# Get your key from https://console.cloud.google.com/ (enable "YouTube Data API v3")
YOUTUBE_API_KEY=your_youtube_api_key_here
